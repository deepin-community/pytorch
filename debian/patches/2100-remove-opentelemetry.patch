Description: get rid of opentelemetry dependency which is not yet in debian
Author: Mo Zhou <lumin@debian.org>
Forwarded: not-needed

--- a/torch/CMakeLists.txt
+++ b/torch/CMakeLists.txt
@@ -87,7 +87,6 @@
 set(TORCH_PYTHON_LINK_LIBRARIES
     Python::Module
     pybind::pybind11
-    opentelemetry::api
     httplib
     nlohmann
     shm
